PORT=3000

# Option A: build JWKS from your RSA public PEM (recommended)
PUBLIC_KEY_PATH=./keys/public.pem
JWT_ALG=RS384
# Must match the `kid` JWT header when signing for Epic (any unique string; UUID is fine)
JWT_KID=ulalo-root-rs384-2026-06

# Option B: serve a pre-built JWKS file (leave PUBLIC_KEY_PATH empty)
# JWKS_JSON_PATH=./public/.well-known/jwks.json

# Epic default cache is long; for sandbox debugging you can use:
# CACHE_CONTROL=no-store
JWK_EPIC_STYLE=true
# Production-style caching (seconds); Epic may respect Cache-Control
CACHE_CONTROL=public, max-age=3600

# Temporary Provider Keys for Testing
PROVIDER_PUBLIC_KEY_PATH=./keys/provider/public.pem

# Patient Keys
PATIENT_PUBLIC_KEY_PATH=./keys/patient/public.pem
