PORT=3000

# --- Epic JWT / JWKS (paraphrased from Epic docs) ---
# - JWKS URL: Epic accepts RSA and EC. Use kid on each JWK and the same kid in JWT headers (recommended).
# - Static JWKS upload (not this server): only RSA kty/e/n are kept; kid/alg are dropped on save; EC is NOT supported there.
# - RSA keys: sign with RS256, RS384, or RS512 (must match how you generated the key).
# - EC P-384: sign with ES384 only; curve and algorithm are fixed at key generation.
# ----------------------------------------------------

# Option A: build JWKS from PEM (recommended) — SPKI public key (BEGIN PUBLIC KEY) or X.509 cert (BEGIN CERTIFICATE)
# Local dev with no key yet: npm run setup:dev (creates keys/public.pem + private.pem; sandbox only)
PUBLIC_KEY_PATH=./keys/public.pem
JWT_ALG=RS384
# Must match `kid` in signed JWT headers. Generate one: node -e "console.log(require('crypto').randomUUID())"
JWT_KID=a1b2c3d4-e5f6-47a8-b9c0-d1e2f3a4b5c6

# Optional EC key in the same JWKS (Epic doc example: RSA + EC P-384). Needs ES384 when signing with EC.
# After: npm run generate-epic-jwks  → use ./keys/ec-public.pem and a second kid
# EC_PUBLIC_KEY_PATH=./keys/ec-public.pem
# EC_JWT_KID=another-uuid-here
# JWT_ALG_EC=ES384

# JWKS JSON shape: true = Epic doc style (RSA: kty,e,kid,n — EC: kty,kid,crv,x,y; no use/alg). false = include use + alg
JWK_EPIC_STYLE=true

# One-shot RSA+EC PEMs + jwks.json file: npm run generate-epic-jwks (optional RSA_JWT_KID / EC_JWT_KID)

# Option B: serve a pre-built JWKS file (leave PUBLIC_KEY_PATH empty)
# JWKS_JSON_PATH=./public/.well-known/jwks.json

# Epic default cache is long; for sandbox debugging you can use:
# CACHE_CONTROL=no-store

# Production-style caching (seconds); Epic may respect Cache-Control
CACHE_CONTROL=public, max-age=3600
